# ============================================================================
# Edge Zone — environment variables
# Copy to .env.local and fill in the values. Never commit .env.local.
# ============================================================================

# ─── Site ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Supabase (required) ────────────────────────────────────────────────────
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe ─────────────────────────────────────────────────────────────────
# Use a NEW restricted key for this project — don't reuse the WP one
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Resend (transactional email) ───────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@theedgezone.com

# ─── Inngest (background jobs) ──────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Vercel (Custom Domains API — added at Phase 0.5) ───────────────────────
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
VERCEL_ACCESS_TOKEN=

# ─── Google Gemini (image generation — logos + arsenal assets) ─────────────
# Get one at ai.google.dev (no credit card needed for the free tier).
# Model used: gemini-2.5-flash-image. Same key powers logo concepts AND
# every Brand Arsenal generator (social templates, merch mockups, etc).
GEMINI_API_KEY=

# ─── Ideogram (legacy — no longer used) ─────────────────────────────────────
# Kept here so existing deploys with this var set don't fail validation.
# The brand designer now uses Gemini exclusively.
IDEOGRAM_API_KEY=

# ─── HeyGen (climb narrator videos) ─────────────────────────────────────────
HEYGEN_API_KEY=

# ─── Google Drive (asset storage) ───────────────────────────────────────────
# Paste the full service account JSON on a single line
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=

# ─── Sharetribe (NILiance bridge) ───────────────────────────────────────────
SHARETRIBE_CLIENT_ID=
SHARETRIBE_CLIENT_SECRET=

# ─── CRM (kept compatible with current Edge Zone CRM adapter) ───────────────
CRM_API_URL=
CRM_API_KEY=
